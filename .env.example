# on-prem-workhorse runtime config.
# Copy to .env and fill in the real values:  cp .env.example .env
# .env is gitignored — it never gets committed.

# API key for the LLM (ik-llama) service
API_KEY=

# API key for the scraper service
SCRAPER_API_KEY=

# Optional HTTP/HTTPS proxy for the scraper's Playwright browser
PROXY_URL=

# LLM model — download URL (used on first run if the model file is missing)
# and the host directory mounted into the containers as /models
HF_MODEL_URL=https://huggingface.co/unsloth/gemma-4-31B-it-GGUF/resolve/main/gemma-4-31B-it-UD-Q6_K_XL.gguf
MODEL_DIR=/home/pawel/models

# MTP draft model for speculative decoding (downloaded on first run if missing)
HF_DRAFT_URL=https://huggingface.co/unsloth/gemma-4-31B-it-GGUF/resolve/main/MTP/gemma-4-31B-it-Q8_0-MTP.gguf
